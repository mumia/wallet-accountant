#!/usr/bin/env bash
# edikt pre-push hook — doc gaps, security scan, and invariant check
# Warns about undocumented public surface changes and security patterns.
# Blocks on invariant violations (exit 1). Doc gaps and security are advisory (exit 0).
#
# Disable: set EDIKT_DOCS_SKIP=1, EDIKT_SECURITY_SKIP=1, or EDIKT_INVARIANT_SKIP=1
# Or add to .edikt/config.yaml:
#   hooks:
#     pre-push: false

# Respect disable flag
if [ "${EDIKT_DOCS_SKIP:-0}" = "1" ] && [ "${EDIKT_SECURITY_SKIP:-0}" = "1" ] && [ "${EDIKT_INVARIANT_SKIP:-0}" = "1" ]; then
  exit 0
fi

# Only run in edikt projects
if [ ! -f ".edikt/config.yaml" ]; then
  exit 0
fi

# Check if disabled in config
if command -v grep >/dev/null 2>&1; then
  if grep -q "pre-push: false" .edikt/config.yaml 2>/dev/null; then
    exit 0
  fi
fi

# Source event logging
if [ -f "$HOME/.edikt/hooks/event-log.sh" ]; then
  source "$HOME/.edikt/hooks/event-log.sh"
fi

# Read base directory from config
BASE=$(grep '^base:' .edikt/config.yaml 2>/dev/null | awk '{print $2}' | tr -d '"' || echo "docs")
[ -z "$BASE" ] && BASE="docs"

# Get the diff being pushed (commits not yet on remote)
REMOTE="$1"
LOCAL_REF="$3"
REMOTE_REF="$4"

# If nothing to compare (new branch, empty push), skip
if [ -z "$LOCAL_REF" ] || [ "$LOCAL_REF" = "0000000000000000000000000000000000000000" ]; then
  exit 0
fi

# Find the base commit to diff from
BASE_COMMIT=$(git merge-base "${REMOTE_REF:-origin/HEAD}" "$LOCAL_REF" 2>/dev/null || echo "")
if [ -z "$BASE_COMMIT" ]; then
  BASE_COMMIT=$(git rev-parse "${REMOTE}/${LOCAL_REF##*/}" 2>/dev/null || echo "")
fi
if [ -z "$BASE_COMMIT" ]; then
  exit 0
fi

DIFF=$(git diff "$BASE_COMMIT" "$LOCAL_REF" -- . 2>/dev/null)
if [ -z "$DIFF" ]; then
  exit 0
fi

BLOCK=false
GAPS=()

# ── Detect new HTTP routes ────────────────────────────────────────────────────
if [ "${EDIKT_DOCS_SKIP:-0}" != "1" ]; then
  NEW_ROUTES=$(echo "$DIFF" | grep "^+" | grep -E \
    '(router\.|app\.(get|post|put|patch|delete|use)\(|http\.HandleFunc|@(Get|Post|Put|Patch|Delete)\(|Route\(|@app\.route|r\.(GET|POST|PUT|PATCH|DELETE)\()' \
    | grep -v "^+++" | sed 's/^+//' | head -5)

  if [ -n "$NEW_ROUTES" ]; then
    API_DOC=$(find . -name "api.md" -o -name "openapi.yaml" -o -name "swagger.json" -o -name "swagger.yaml" 2>/dev/null | grep -v ".git" | head -1)
    if [ -n "$API_DOC" ]; then
      GAPS+=("New HTTP route(s) detected — check ${API_DOC}")
    else
      GAPS+=("New HTTP route(s) detected — no API docs found (consider docs/api.md)")
    fi
  fi

  # ── Detect new env vars ───────────────────────────────────────────────────────
  NEW_ENVS=$(echo "$DIFF" | grep "^+" | grep -E \
    '(os\.Getenv\(|process\.env\.|ENV\[|os\.environ|getenv\()' \
    | grep -v "^+++" | grep -oE '[A-Z][A-Z0-9_]{2,}' | sort -u | head -5)

  if [ -n "$NEW_ENVS" ]; then
    README=$(find . -maxdepth 2 -name "README.md" -o -name "README.rst" 2>/dev/null | grep -v ".git" | head -1)
    for ENV_VAR in $NEW_ENVS; do
      if [ -n "$README" ]; then
        if ! grep -q "$ENV_VAR" "$README" 2>/dev/null; then
          GAPS+=("New env var ${ENV_VAR} — not in ${README}")
        fi
      else
        GAPS+=("New env var ${ENV_VAR} — no README found to document it")
      fi
    done
  fi

  # ── Detect new docker-compose services ────────────────────────────────────────
  NEW_SERVICES=$(echo "$DIFF" | grep "^+" | grep -E '^+[a-zA-Z][a-zA-Z0-9_-]+:$' \
    | grep -v "^+++" | sed 's/^+//' | sed 's/:$//' | head -5)

  COMPOSE_CHANGED=$(echo "$DIFF" | grep "^diff --git" | grep -E "docker-compose" | head -1)
  if [ -n "$COMPOSE_CHANGED" ] && [ -n "$NEW_SERVICES" ]; then
    INFRA_DOC=$(find . -name "infrastructure.md" -o -name "infra.md" -o -name "architecture.md" 2>/dev/null | grep -v ".git" | head -1)
    for SVC in $NEW_SERVICES; do
      GAPS+=("New docker-compose service '${SVC}'${INFRA_DOC:+ — check ${INFRA_DOC}}")
    done
  fi

  if [ ${#GAPS[@]} -gt 0 ]; then
    echo ""
    echo "📄 edikt: doc gaps detected (${#GAPS[@]}):"
    for GAP in "${GAPS[@]}"; do
      echo "   • ${GAP}"
    done
    echo ""
    echo "   Run /edikt:docs:review to review. Pushing anyway."
    echo "   To skip this check: EDIKT_DOCS_SKIP=1 git push"
    echo ""
  fi
fi

# ── Security scan ─────────────────────────────────────────────────────────────
if [ "${EDIKT_SECURITY_SKIP:-0}" != "1" ]; then
  if ! grep -q "pre-push-security: false" .edikt/config.yaml 2>/dev/null; then
    SEC_FINDINGS=""

    # Hardcoded secrets
    SECRETS=$(echo "$DIFF" | grep "^+" | grep -v "^+++" | grep -iE '(api_key|password|secret|token)\s*=\s*["'"'"'][^"'"'"']{8,}' | head -3)
    [ -n "$SECRETS" ] && SEC_FINDINGS="${SEC_FINDINGS}   • Possible hardcoded secret\n"

    # SQL string concatenation
    SQL=$(echo "$DIFF" | grep "^+" | grep -v "^+++" | grep -E '"(SELECT|INSERT|UPDATE|DELETE).*"\s*\+' | head -3)
    [ -n "$SQL" ] && SEC_FINDINGS="${SEC_FINDINGS}   • SQL string concatenation (injection risk)\n"

    # TODO security comments
    TODOS=$(echo "$DIFF" | grep "^+" | grep -v "^+++" | grep -iE 'TODO.*(auth|security|validate|sanitize)' | head -3)
    [ -n "$TODOS" ] && SEC_FINDINGS="${SEC_FINDINGS}   • Security TODO comments not resolved\n"

    if [ -n "$SEC_FINDINGS" ]; then
      echo ""
      echo "🔒 edikt: security patterns detected:"
      printf "$SEC_FINDINGS"
      echo ""
      echo "   Run /edikt:sdlc:audit to review. Pushing anyway."
      echo "   To skip: EDIKT_SECURITY_SKIP=1 git push"
      echo ""
    fi
  fi
fi

# ── Invariant check (BLOCKS on violation) ─────────────────────────────────────
if [ "${EDIKT_INVARIANT_SKIP:-0}" != "1" ]; then
  if ! grep -q "pre-push-invariants: false" .edikt/config.yaml 2>/dev/null; then
    # Find invariant files
    INV_DIR=""
    for dir in "$BASE/invariants" "$BASE/architecture/invariants"; do
      if [ -d "$dir" ]; then
        INV_DIR="$dir"
        break
      fi
    done

    if [ -n "$INV_DIR" ]; then
      INV_VIOLATIONS=()
      STAGED_FILES=$(git diff --name-only "$BASE_COMMIT" "$LOCAL_REF" 2>/dev/null)

      for inv_file in "$INV_DIR"/*.md; do
        [ ! -f "$inv_file" ] && continue

        INV_NAME=$(head -1 "$inv_file" | sed 's/^# //')

        # Extract the rule section content (between ## Rule and next ##)
        RULE_CONTENT=$(awk '/^## Rule/{found=1; next} /^## /{found=0} found{print}' "$inv_file")
        [ -z "$RULE_CONTENT" ] && continue

        # Check for known invariant patterns
        # INV: "no compiled code" / "no build step" / "plain markdown only"
        if echo "$RULE_CONTENT" | grep -qiE 'no (compiled|binary|build step|TypeScript|npm)'; then
          # Check for package.json, go.mod, tsconfig at root
          for bad_file in package.json tsconfig.json go.mod Makefile; do
            if echo "$STAGED_FILES" | grep -q "^${bad_file}$"; then
              INV_VIOLATIONS+=("${INV_NAME}: ${bad_file} added — invariant says no compiled code/build step")
            fi
          done
        fi

        # INV: "commands are .md files"
        if echo "$RULE_CONTENT" | grep -qiE 'commands.*\.md|\.md.*commands'; then
          NON_MD_COMMANDS=$(echo "$STAGED_FILES" | grep '^commands/' | grep -v '\.md$' | head -3)
          if [ -n "$NON_MD_COMMANDS" ]; then
            for cmd_file in $NON_MD_COMMANDS; do
              INV_VIOLATIONS+=("${INV_NAME}: ${cmd_file} — commands must be .md files")
            done
          fi
        fi

        # INV: "no dependencies" / "no runtime dependencies"
        if echo "$RULE_CONTENT" | grep -qiE 'no (runtime )?dependencies'; then
          if echo "$STAGED_FILES" | grep -qE '^(package\.json|requirements\.txt|go\.mod|Gemfile|composer\.json)$'; then
            MATCHED=$(echo "$STAGED_FILES" | grep -E '^(package\.json|requirements\.txt|go\.mod|Gemfile|composer\.json)$' | head -1)
            INV_VIOLATIONS+=("${INV_NAME}: ${MATCHED} added — invariant says no dependencies")
          fi
        fi
      done

      if [ ${#INV_VIOLATIONS[@]} -gt 0 ]; then
        echo ""
        echo "⛔ edikt: INVARIANT VIOLATION — push blocked"
        for V in "${INV_VIOLATIONS[@]}"; do
          echo "   • ${V}"
        done
        echo ""
        echo "   Fix the violation or override: EDIKT_INVARIANT_SKIP=1 git push"
        echo "   To disable: add 'pre-push-invariants: false' under 'hooks:' in .edikt/config.yaml"
        echo ""

        # Log the violation
        if type edikt_log_event >/dev/null 2>&1; then
          for V in "${INV_VIOLATIONS[@]}"; do
            ESCAPED_V=$(echo "$V" | sed 's/"/\\"/g')
            edikt_log_event "invariant_violation" "{\"finding\":\"${ESCAPED_V}\",\"context\":\"pre-push\"}"
          done
        fi

        BLOCK=true
      fi
    fi
  fi
fi

# Exit with appropriate code
if [ "$BLOCK" = true ]; then
  exit 1
fi
exit 0
